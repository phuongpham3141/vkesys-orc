# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=8000

# Web server: 'true' = waitress (production-grade thread pool, recommended).
# Set to 'false' để dùng Werkzeug dev server với hot-reload + traceback page.
USE_WAITRESS=true
WAITRESS_THREADS=32
WAITRESS_CONNECTION_LIMIT=400

# DB connection pool (chỉ áp dụng cho Flask web process).
#   Subprocess workers tự động dùng pool nhỏ (2+3) — không cần config riêng.
#
# Tổng PostgreSQL connection thực tế:
#   = (DB_POOL_SIZE + DB_MAX_OVERFLOW)        ← Flask web
#   + (subprocess workers × 5)                 ← run_one_job.py
#   + 5                                        ← scheduler + admin tools
#
# Với MAX_CONCURRENT_WORKERS=20:
#   pool_size=10 / overflow=20 → 30 + 20×5 + 5 = 135 connections
#   pool_size=50 / overflow=100 → 150 + 20×5 + 5 = 255 connections
#
# PostgreSQL phải có max_connections >= tổng số trên + 20 (an toàn).
# Default PG = 100 → KHÔNG đủ nếu pool_size > 30.
# Xem docs/SCALING.md để biết cách tune PostgreSQL + VPS spec.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30

# Cache static assets (galaxy.css, app.js, ...) trong N giây
STATIC_CACHE_SECONDS=3600

# Log request chậm hơn N ms để debug bottleneck
SLOW_REQUEST_MS=500
SECRET_KEY=change-me-to-random-64-chars
ENCRYPTION_KEY=generate-with-Fernet.generate_key

# Database
DATABASE_URL=postgresql+psycopg://postgres:Phuong2606@localhost:5432/vic_ocr

# File storage
UPLOAD_FOLDER=./uploads
OUTPUT_FOLDER=./outputs
MAX_UPLOAD_MB=50

# OCR
OCR_MAX_WORKERS=2
# Document AI: 1 = mỗi trang là 1 API call (an toàn nhất, lưu DB sau từng trang).
# Tăng lên 30 nếu bạn ưu tiên latency và chấp nhận mất nguyên chunk khi 1 trang fail.
DOCUMENT_AI_PAGES_PER_REQUEST=1
# OCR_WORKER_MODE: 'external' (default — run worker.py separately, web stays
# fast and never crashes from reloader/threading races) or 'inprocess'
# (legacy — Flask runs OCR in its own ThreadPoolExecutor; only for dev).
OCR_WORKER_MODE=external
PDF_DPI=200
POPPLER_PATH=
# Set to 'true' if you want Werkzeug to auto-restart on code change (off by
# default because the reloader races with long-running OCR threads).
FLASK_AUTO_RELOAD=false

# Folder watcher
FOLDER_WATCH_ENABLED=false
WATCH_FOLDER_PATH=./watch_folder
WATCH_FOLDER_PROCESSED_PATH=./watch_folder_processed
WATCH_FOLDER_USER_ID=1
WATCH_FOLDER_ENGINE=tesseract
WATCH_INTERVAL_SECONDS=30

# Google Vision (system-wide fallback if user has no own config)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-vision.json

# Mistral (system-wide fallback)
MISTRAL_API_KEY=

# Tesseract Windows path
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Rate limiting
API_RATE_LIMIT=60/minute
